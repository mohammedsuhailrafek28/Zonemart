# Public Supabase project URL. Safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anonymous/publishable key. Safe for browser use with RLS enabled.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only key for trusted administrative jobs. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Password used only when creating local/demo vendor accounts with `npm run seed`.
DEMO_VENDOR_PASSWORD=

# Password used only when creating a local/demo customer account with `npm run seed`.
DEMO_CUSTOMER_PASSWORD=
